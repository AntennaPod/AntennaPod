<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
        xmlns:android="http://schemas.android.com/apk/res/android">

    <Preference
            android:layout="@layout/about_teaser"/>
    <Preference
            android:key="about_version"
            android:title="@string/antennapod_version"
            android:icon="@drawable/ic_star"
            android:summary="1.7.2 (asd8qs)"/>
    <Preference
            android:key="about_contributors"
            android:icon="@drawable/ic_contributors"
            android:summary="@string/contributors_summary"
            android:title="@string/contributors"/>
    <Preference
            android:key="about_privacy_policy"
            android:icon="@drawable/ic_policy"
            android:summary="www.antennapod.org/privacy"
            android:title="@string/privacy_policy"/>
    <Preference
            android:key="about_licenses"
            android:icon="@drawable/ic_info"
            android:summary="@string/licenses_summary"
            android:title="@string/licenses"/>
    <Preference
            android:key="about_fork_notice"
            android:icon="@drawable/ic_info"
            android:title="@string/fork_notice_title"
            android:summary="@string/fork_notice_summary"/>

    <Preference
            android:key="about_upstream"
            android:icon="@drawable/ic_info"
            android:summary="@string/fork_notice_upstream"
            android:title="@string/fork_notice_upstream_title"/>

</PreferenceScreen>
